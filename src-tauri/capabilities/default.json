{
  "$schema": "https://schema.tauri.app/config/2",
  "identifier": "default",
  "description": "SecuScan AI default capability",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "dialog:default",
    "dialog:allow-open",
    "dialog:allow-save",
    "fs:default",
    "fs:allow-read-file",
    "fs:allow-read-dir",
    "fs:allow-write-file",
    "fs:allow-mkdir",
    "fs:allow-exists"
  ]
}
